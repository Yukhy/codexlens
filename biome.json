{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "includes": ["src/**/*.js", "test/**/*.js"]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noRedundantUseStrict": "off"
      }
    }
  },
  "javascript": {
    "globals": ["document", "localStorage", "window"]
  }
}
