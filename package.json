{
  "name": "codexlens",
  "version": "0.2.0",
  "description": "Read-only macOS menu bar lens for local Codex and Claude Code activity.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "open:mac": "open -n -a \"$PWD/node_modules/electron/dist/Electron.app\" --args \"$PWD\"",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --publish never --config.mac.identity=null --config.mac.notarize=false",
    "screenshots": "electron scripts/capture-screenshots.js",
    "scan": "node src/cli.js",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "agent-observability",
    "ai-agents",
    "claude",
    "claude-code",
    "codex",
    "codex-cli",
    "codex-mcp",
    "electron",
    "macos",
    "menubar",
    "mcp",
    "mcp-server",
    "openai-codex"
  ],
  "author": "Yukhy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yukhy/codexlens.git"
  },
  "bugs": {
    "url": "https://github.com/Yukhy/codexlens/issues"
  },
  "homepage": "https://github.com/Yukhy/codexlens#readme",
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.yukhy.codexlens",
    "productName": "CodexLens",
    "copyright": "Copyright © 2026 Yukhy",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "src/**/*",
      "README.md",
      "LICENSE",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Yukhy",
        "repo": "codexlens",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3"
  }
}
