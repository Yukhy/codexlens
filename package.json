  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yukhy/codexlens.git"
  },
  "bugs": {
    "url": "https://github.com/Yukhy/codexlens/issues"
  },
  "homepage": "https://github.com/Yukhy/codexlens#readme",
  "engines": {
    "node": ">=20"
  },
